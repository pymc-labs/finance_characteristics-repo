# =============================================================================
# Freyberger 62 Characteristics - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then edit .env with your actual WRDS username.
# =============================================================================

# Your WRDS username (required for data download)
WRDS_USER=your_wrds_username

# Data directory - where input data files are stored
# Default: ./data/inputs (relative to project folder)
DATA_DIR=./data/inputs

# Output directory - where characteristic files will be saved
# Default: ./data/outputs (relative to project folder)
OUTPUT_DIR=./data/outputs
